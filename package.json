{
  "name": "pet-gato-motivador",
  "version": "1.0.0",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder"
  },
  "build": {
    "appId": "com.tiagoa.petgato",
    "productName": "Pet Gato Motivador",
    "win": {
      "target": "nsis",
      "icon": "assets/icon.ico"
    },
    "nsis": {
      "createDesktopShortcut": true,
      "shortcutName": "Pet Gato"
    }
  }
}